APP_NAME=SlideMind
API_PREFIX=/api
DEBUG=true

MONGO_URI=mongodb://mongodb:27017
MONGO_DB=slidemind

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=slidemind_password

MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=landslide_knowledge_vectors
EMBEDDING_DIM=384

REDIS_URL=redis://redis:6379/0
UPLOAD_DIR=/app/uploads
ASYNC_IMPORTS=false

LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Docker Hub mirror preset for restricted networks.
# If one mirror is unavailable, replace these values with another reachable registry.
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.11-slim
NODE_IMAGE=docker.m.daocloud.io/library/node:24-alpine
MONGO_IMAGE=docker.m.daocloud.io/library/mongo:7
NEO4J_IMAGE=docker.m.daocloud.io/library/neo4j:5-community
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
ETCD_IMAGE=m.daocloud.io/quay.io/coreos/etcd:v3.5.18
MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2025-04-22T22-12-26Z
MILVUS_IMAGE=docker.m.daocloud.io/milvusdb/milvus:v2.5.10
